AI_IMAGE_CHOOSER_QUALITY_WEIGHT=0.55
AI_IMAGE_CHOOSER_COST_WEIGHT=0.35
AI_IMAGE_CHOOSER_POPULARITY_WEIGHT=0.10
AI_IMAGE_CHOOSER_MIN_QUALITY=60
AI_IMAGE_CHOOSER_MAX_USD_PER_IMAGE=0.10
AI_IMAGE_CHOOSER_LLM_ENABLED=true
AI_IMAGE_CHOOSER_LLM_PROVIDER=openrouter
