APP_NAME=Mentrovia
APP_ENV=local
APP_KEY=
PROFILE_FINGERPRINT_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PASSWORD_RESET_MIN_RESPONSE_MS=250
HSTS_ENABLED=true
CSP_REPORT_ONLY_ENABLED=true
CSP_REPORT_MAX_BYTES=32768
TRUSTED_PROXIES=127.0.0.1,::1

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mentrovia_db
DB_USERNAME=mentrovia
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
LIFECYCLE_QUEUE_CONNECTION=lifecycle-database
LIFECYCLE_QUEUE_DB_CONNECTION=mariadb
LIFECYCLE_QUEUE_TABLE=jobs
LIFECYCLE_PHOTO_QUEUE=photo-lifecycle
LIFECYCLE_SECURITY_QUEUE=security-erasure
LIFECYCLE_QUEUE_RETRY_AFTER=900
LIFECYCLE_CLAIM_SECONDS=600
LIFECYCLE_REQUIRE_SCHEDULER_HEARTBEAT=true
LIFECYCLE_SCHEDULER_HEARTBEAT_MAX_AGE=180
LIFECYCLE_QUEUE_BACKLOG_WARNING=1000
LIFECYCLE_OLDEST_JOB_WARNING_SECONDS=900

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

OPENROUTER_API_KEY=
TEXT_GENERATION_CONFIG_VERSION=v2
TEXT_OPENROUTER_MAX_PROMPT_PRICE=1
TEXT_OPENROUTER_MAX_COMPLETION_PRICE=2
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
OPENAI_API_KEY=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_STANDARD_MONTHLY_PRICE=
STRIPE_STANDARD_YEARLY_PRICE=
CASHIER_CURRENCY=usd
CASHIER_PATH=stripe

PHOTOSTUDIO_IMAGE_DISK=s3
PHOTOSTUDIO_MAX_BATCH_INPUTS=12
DB_QUEUE_RETRY_AFTER=390
REDIS_QUEUE_RETRY_AFTER=390
PHOTOSTUDIO_UPLOADED_PREFIX=uploaded_
PHOTOSTUDIO_GENERATED_PREFIX=generated_
PHOTOSTUDIO_PROVIDER=auto
PHOTOSTUDIO_MODEL=
PHOTOSTUDIO_RESULTS_PER_BATCH=3
PHOTOSTUDIO_HTTP_CONNECT_TIMEOUT=10
PHOTOSTUDIO_MAX_OUTPUT_BYTES=26214400
PHOTOSTUDIO_MAX_OUTPUT_DIMENSION=8192
PHOTOSTUDIO_MAX_OUTPUT_PIXELS=40000000
PHOTOSTUDIO_OPERATION_LEASE_SECONDS=600
ACCOUNT_ERASURE_RETRY_SECONDS=30
REPLICATE_OUTPUT_HOSTS=replicate.delivery
PHOTOSTUDIO_ANALYSIS_PROVIDER=openrouter
PHOTOSTUDIO_ANALYSIS_MODEL=google/gemini-2.5-flash
PHOTOSTUDIO_NODE_BINARY=node
PHOTOSTUDIO_PROCESSING_TIMEOUT=120
PHOTOSTUDIO_MAX_UPLOAD_MB=25
PHOTOSTUDIO_MAX_SOURCE_DIMENSION=8000
