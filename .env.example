APP_NAME=Mentrovia
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mentrovia_db
DB_USERNAME=mentrovia
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
OPENAI_API_KEY=

PHOTOSTUDIO_IMAGE_DISK=s3
PHOTOSTUDIO_UPLOADED_PREFIX=uploaded_
PHOTOSTUDIO_GENERATED_PREFIX=generated_
PHOTOSTUDIO_PROVIDER=auto
PHOTOSTUDIO_MODEL=
PHOTOSTUDIO_RESULTS_PER_BATCH=3
PHOTOSTUDIO_ANALYSIS_PROVIDER=openrouter
PHOTOSTUDIO_ANALYSIS_MODEL=google/gemini-2.5-flash
PHOTOSTUDIO_NODE_BINARY=node
PHOTOSTUDIO_PROCESSING_TIMEOUT=120
PHOTOSTUDIO_MAX_UPLOAD_MB=25
PHOTOSTUDIO_MAX_SOURCE_DIMENSION=8000
PHOTOSTUDIO_ORIGINAL_RETENTION_DAYS=30

AI_IMAGE_CHOOSER_QUALITY_WEIGHT=0.55
AI_IMAGE_CHOOSER_COST_WEIGHT=0.35
AI_IMAGE_CHOOSER_POPULARITY_WEIGHT=0.10
AI_IMAGE_CHOOSER_MIN_QUALITY=60
AI_IMAGE_CHOOSER_MAX_USD_PER_IMAGE=0.10
AI_IMAGE_CHOOSER_LLM_ENABLED=true
AI_IMAGE_CHOOSER_LLM_PROVIDER=openrouter
AI_IMAGE_CHOOSER_LLM_MODEL=openai/gpt-oss-120b:free
AI_IMAGE_CHOOSER_LLM_TOP_CANDIDATES=8
AI_IMAGE_CHOOSER_CACHE_TTL_HOURS=24
AI_IMAGE_CHOOSER_TIMEOUT_SECONDS=20

VITE_APP_NAME="${APP_NAME}"
